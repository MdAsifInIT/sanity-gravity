    "gc": {"name": "gemini-cli",  "requires_gui": False},
    "cc": {"name": "claude-cli",  "requires_gui": False},
}
CONNECTORS = {
    "ssh":  {"name": "ssh",      "requires_gui": False},
    "kasm": {"name": "kasm",     "requires_gui": True},
    "vnc":  {"name": "vnc",      "requires_gui": True},
}
DESKTOPS = {
    "xfce": {"name": "xfce", "has_gui": True},
    "none": {"name": "none", "has_gui": False},
}

DEFAULT_TAG = "ag-xfce-kasm"

def parse_tag(tag):
    """Parses a dimension-based tag (e.g. 'ag-xfce-kasm') into (agent, desktop, connector).
    Raises ValueError if the tag is invalid or violates constraints."""
    parts = tag.split("-")
    if len(parts) != 3:
        raise ValueError(f"Invalid tag format '{tag}'. Expected {{agent}}-{{desktop}}-{{connector}} (e.g. ag-xfce-kasm)")
    agent, desktop, connector = parts
    if agent not in AGENTS:
        raise ValueError(f"Unknown agent '{agent}'. Valid: {', '.join(AGENTS.keys())}")
    if desktop not in DESKTOPS:
        raise ValueError(f"Unknown desktop '{desktop}'. Valid: {', '.join(DESKTOPS.keys())}")
    if connector not in CONNECTORS:
        raise ValueError(f"Unknown connector '{connector}'. Valid: {', '.join(CONNECTORS.keys())}")
    # Constraint: GUI connector requires GUI desktop
    if CONNECTORS[connector]["requires_gui"] and not DESKTOPS[desktop]["has_gui"]:
        raise ValueError(f"Connector '{connector}' requires a GUI desktop, but '{desktop}' is headless")
    # Constraint: GUI agent requires GUI desktop
    if AGENTS[agent]["requires_gui"] and not DESKTOPS[desktop]["has_gui"]:
        raise ValueError(f"Agent '{agent}' requires a GUI desktop, but '{desktop}' is headless")
    return agent, desktop, connector

def generate_valid_tags():
    """Returns a list of all valid tag combinations, filtered by constraints."""
    tags = []
    for a, a_info in AGENTS.items():
        for d, d_info in DESKTOPS.items():
            for c, c_info in CONNECTORS.items():
                # Rule 1: GUI connector needs GUI desktop
                if c_info["requires_gui"] and not d_info["has_gui"]:
                    continue
                # Rule 2: GUI agent needs GUI desktop
                if a_info["requires_gui"] and not d_info["has_gui"]:
                    continue
                tags.append(f"{a}-{d}-{c}")
    return tags

