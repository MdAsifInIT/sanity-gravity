def open_cmd(args):
    """Opens the active project's web interface."""
    project_name = args.name
    
    # Identify project
    if project_name == "sanity-gravity":
        active = get_active_projects()
        if not active:
             print_error("No active projects found.")
             return
        project_name = active[0]

    # Find active variant
    target_variant = None
    container_name = None
    for v in VARIANTS:
        cname = f"{project_name}-{v}-1"
        try:
             out = run_command(f"docker inspect -f '{{{{.State.Running}}}}' {cname}", capture=True, check=False)
             if out == "true":
                 target_variant = v
                 container_name = cname
                 break
        except:
             pass
             
    if not container_name:
         print_error(f"No running containers found for {project_name}.")
         return

    # Determine URL
    url = None
    
    # We need to resolve ports again if they were ephemeral
    # But usually get_project_env gives us the ENV vars stored in the container config.
    # HOWEVER, ephemeral ports are mapped on host, the ENV var inside might say "0".
    # Wait, in 'up', we update env_vars with resolved ports? No, we update python var but restart container?
    # No, 'up' logic runs with '0' env var, then queries 'docker port' to show info.
    # The container itself thinks it's 0? Yes.
    # So we must query `docker port` to find the real host port.
    
    compose_file_arg = f"-f {COMPOSE_FILE}" 
    # Determine gpu/git files? Just using base file usually works for port query if project name matches
    
    def resolve_port(service, internal):
        try:
            # We must use project name
            out = run_command(f"docker compose -p {project_name} {compose_file_arg} port {service} {internal}", capture=True, check=False)
            if ":" in out:
                return out.split(":")[-1]
        except:
            pass
        return None

    if target_variant == "kasm":
        port = resolve_port("kasm", "8444")
        if port:
            url = f"https://localhost:{port}"
            
    elif target_variant == "vnc":
        # Prefer noVNC
        port = resolve_port("vnc", "6901")
        if port:
            url = f"http://localhost:{port}/vnc.html"
            
    elif target_variant == "core":
        print_warning(f"Variant '{target_variant}' has no web interface.")
        return

    if url:
        print_success(f"Opening {url} ...")
        webbrowser.open(url)
    else:
        print_error("Could not resolve accessible URL.")

def snapshot_cmd(args):
    """Snapshots a running container to a new image."""
    project_name = args.name
    variant = args.variant
    tag = args.tag
    
    # Identify active projects
    if project_name == "sanity-gravity":
        active = get_active_projects()
        if not active:
             print_error("No active projects found.")
             print("Tip: Use --name <project> to specify a project.")
             return
        if len(active) > 1:
             print_error(f"Multiple active projects found: {', '.join(active)}")
             print("Please specify a project with --name.")
             return
        project_name = active[0]

    # If variant not specified, try to detect
    container_id = None
    target_variant = None
    
    if variant:
        target_variant = variant
        container_name = f"{project_name}-{variant}-1"
        out = run_command(f"docker inspect {container_name}", capture=True, check=False)
        if out and out.strip() != "[]":
             container_id = container_name
        else:
             print_error(f"無法找到容器：{container_name}。請確認該環境已啟動，或指定正確的 --variant。")
             return
    else:
        # Auto-detect
        found_variants = []
        for v in VARIANTS:
            cname = f"{project_name}-{v}-1"
            out = run_command(f"docker inspect {cname}", capture=True, check=False)
            if out and out.strip() != "[]":
                found_variants.append(v)
        
        if not found_variants:
            print_error(f"在專案「{project_name}」中找不到任何可用的容器。")
            print_info("提示：此專案可能尚未啟動，請先執行 './sanity-cli up'。")
            return
        elif len(found_variants) == 1:
            target_variant = found_variants[0]
            container_id = f"{project_name}-{target_variant}-1"
        else:
            print_info(f"偵測到多個運行中的環境：{', '.join(found_variants)}")
            if not sys.stdin.isatty():
                print_error("當前為非互動模式，請使用 --variant 明確指定要 snapshot 的環境。")
                return
            
            print(f"{Colors.BOLD}請選擇要建立 Snapshot 的環境：{Colors.ENDC}")
            for i, v in enumerate(found_variants):
                print(f"  [{i+1}] {v}")
            
            while True:
                choice = input(f"{Colors.OKBLUE}請輸入數字 (1-{len(found_variants)}): {Colors.ENDC}").strip()
                if choice.isdigit() and 1 <= int(choice) <= len(found_variants):
                    target_variant = found_variants[int(choice)-1]
                    container_id = f"{project_name}-{target_variant}-1"
                    break
                print_warning("無效的輸入，請重新選擇。")
            
    print_header(f"Snapshotting {container_id} -> {tag}")
    
    try:
        # Commit the container
        # We pause the container by default (docker commit default behavior)
        run_command(f"docker commit {container_id} {tag}")
        print_success(f"Snapshot created: {tag}")
        print(f"\n{Colors.OKBLUE}To use this snapshot:{Colors.ENDC}")
        print(f"  ./sanity-cli up -v {target_variant} --name new-env --image {tag}")
        
    except Exception as e:
        print_error(f"Snapshot failed: {e}")

