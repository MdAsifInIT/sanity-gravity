        return

    # Find running variant container
    target_variant = None
    container_name = None
    for v in VARIANTS:
        cname = f"{project_name}-{v}-1"
        try:
             out = run_command(f"docker inspect -f '{{{{.State.Running}}}}' {cname}", capture=True, check=False)
             if out == "true":
                 target_variant = v
                 container_name = cname
                 break
        except:
             pass

    if not container_name:
         print_error(f"No running containers found for {project_name}.")
         return

    print_header(f"IDE Maintenance ({project_name})")
    print_info(f"Executing gravity-cli {subcommand} in {container_name}...")
    
    # Always hot-inject the latest gravity-cli into the container to ensure
    # legacy environments receive the latest bugfixes and protection logic.
    print_info("Hot-injecting latest gravity-cli and chrome-cleanup for compatibility...")
    base_dir = os.path.dirname(os.path.abspath(__file__))
    cli_src = os.path.join(base_dir, "sandbox", "rootfs", "usr", "local", "bin", "gravity-cli")
    cleanup_src = os.path.join(base_dir, "sandbox", "rootfs", "usr", "local", "bin", "chrome-cleanup.sh")
    
    inject_cmd_1 = f"docker cp {cli_src} {container_name}:/usr/local/bin/gravity-cli"
    inject_cmd_1_b = f"docker cp {cleanup_src} {container_name}:/usr/local/bin/chrome-cleanup.sh"
    inject_cmd_2 = f"docker exec -u root {container_name} chmod +x /usr/local/bin/gravity-cli /usr/local/bin/chrome-cleanup.sh"
    
    try:
        subprocess.check_call(inject_cmd_1, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.check_call(inject_cmd_1_b, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        subprocess.check_call(inject_cmd_2, shell=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except subprocess.CalledProcessError:
        print_error("Failed to hot-inject gravity-cli. Container might be highly incompatible.")
        sys.exit(1)

    # Execute gravity-cli as root inside the container
    cmd = f"docker exec -it -u root {container_name} /usr/local/bin/gravity-cli {subcommand}"
    try:
        subprocess.check_call(cmd, shell=True)
    except subprocess.CalledProcessError:
        sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description="Antigravity Sandbox CLI")
    subparsers = parser.add_subparsers(dest="command", help="Command to execute")

    # Check Command
    parser_check = subparsers.add_parser("check", help="Check prerequisites")
    parser_check.set_defaults(func=check_prereqs)

    # Build Command
    parser_build = subparsers.add_parser("build", help="Build sandbox images")
    parser_build.add_argument("variant", nargs="*", help="Variant to build (default: all)", default=["all"])
    parser_build.set_defaults(func=build)

    # Install Command (Alias)
    parser_install = subparsers.add_parser("install", help="Install/Build sandbox environment")
    parser_install.add_argument("variant", nargs="*", help="Variant to install (default: all)", default=["all"])
    parser_install.set_defaults(func=install)

    # Up Command (formerly Run)
    parser_up = subparsers.add_parser("up", help="Create and start sandbox (docker compose up)")
    parser_up.add_argument("--variant", "-v", required=True, help="Variant to run", choices=VARIANTS)
    parser_up.add_argument("--ssh-port", "-p", default="2222", help="Host port for SSH (default: 2222)")
    parser_up.add_argument("--kasm-port", default="8444", help="Host port for KasmVNC (default: 8444)")
    parser_up.add_argument("--vnc-port", default="5901", help="Host port for VNC (default: 5901)")
    parser_up.add_argument("--novnc-port", default="6901", help="Host port for noVNC (default: 6901)")
    parser_up.add_argument("--password", default="antigravity", help="Password for SSH/VNC (default: antigravity)")
    parser_up.add_argument("--gpu", action="store_true", help="Enable Nvidia GPU support (requires docker-compose.gpu.yml)")
    parser_up.add_argument("--skip-check", action="store_true", help="Skip prerequisite checks")
    parser_up.add_argument("--workspace", "-w", default=None, help="Path to workspace directory (default: ./workspace)")
    parser_up.add_argument("--name", "-n", default="sanity-gravity", help="Project name for multi-instance support (default: sanity-gravity)")
    parser_up.add_argument("--cpus", default=None, help="CPU limit (e.g. 1.5)")
    parser_up.add_argument("--memory", default=None, help="Memory limit (e.g. 4G)")
    parser_up.add_argument("--image", default=None, help="Use custom base image (Snapshot)")
    parser_up.set_defaults(func=up)

    # Run Command (Alias for Up)
    parser_run = subparsers.add_parser("run", help="Alias for 'up'")
