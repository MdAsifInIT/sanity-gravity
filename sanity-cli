#!/usr/bin/env python3
"""Sanity-Gravity CLI entry point.

All logic lives in the :mod:`sanity_gravity` package under ``lib/``;
this shim only injects ``lib/`` onto ``sys.path`` so the package is
importable without installation, then hands control to
:func:`sanity_gravity.cli.main.main`.
"""
import os
import sys

_LIB = os.path.join(os.path.dirname(os.path.abspath(__file__)), "lib")
if _LIB not in sys.path:
    sys.path.insert(0, _LIB)

from sanity_gravity.cli.main import main  # noqa: E402


if __name__ == "__main__":
    main()
