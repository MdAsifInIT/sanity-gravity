#!/bin/bash
# gravity-cli: The Container-side Management Tool for Sanity-Gravity
# This tool handles IDE updates, system repairs, and deep maintenance
# from *inside* the sandbox environment, securely.

set -e

# ANSI Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color
BOLD='\033[1m'

print_error() { echo -e "${RED}${BOLD}[ERROR]${NC} $1"; }
print_success() { echo -e "${GREEN}${BOLD}[SUCCESS]${NC} $1"; }
print_info() { echo -e "${BLUE}${BOLD}[INFO]${NC} $1"; }
print_warning() { echo -e "${YELLOW}${BOLD}[WARNING]${NC} $1"; }

# Must be run as root
if [ "$EUID" -ne 0 ]; then
  print_error "gravity-cli must be run as root."
  echo "Try with: sudo gravity-cli \"\$@\""
  exit 1
fi

show_help() {
    echo "Usage: gravity-cli <command> [options]"
    echo ""
    echo "Commands:"
    echo "  update-ide     Safely update the Antigravity IDE to the latest version."
    echo "  reinstall-ide  Completely wipe and cleanly reinstall the Antigravity IDE."
    echo "  help           Show this help message."
    echo ""
    echo "Note: This tool is meant to be run INSIDE the Sanity-Gravity container."
}

# Ensure divergence is still active
ensure_wrapper_protection() {
    print_info "Verifying wrapper protection mechanisms..."
    
    local CURRENT_DIVERT
    CURRENT_DIVERT=$(dpkg-divert --list /usr/share/antigravity/antigravity | awk '{print $NF}')

    if [ "$CURRENT_DIVERT" != "/usr/share/antigravity/antigravity-bin" ]; then
        print_warning "Diverting Antigravity to robust binary path..."
        
        # Remove old diversion if it exists
        if [ -n "$CURRENT_DIVERT" ]; then
            # Remove the manual wrapper first to avoid collision with --rename
            rm -f /usr/share/antigravity/antigravity
            dpkg-divert --remove --rename /usr/share/antigravity/antigravity
        fi

        # Ensure the binary is at the new path
        if [ -f "/usr/share/antigravity/antigravity-original" ] && [ ! -f "/usr/share/antigravity/antigravity-bin" ]; then
             mv "/usr/share/antigravity/antigravity-original" "/usr/share/antigravity/antigravity-bin"
        fi

        # Apply new diversion
        dpkg-divert --add --rename --divert /usr/share/antigravity/antigravity-bin /usr/share/antigravity/antigravity
    fi

    # Create the Master Wrapper content
    # Handles Node-mode CLI vs Chromium-mode GUI/Zygote correctly.
    cat << 'EOF' > /usr/share/antigravity/antigravity
#!/bin/bash
# Master Wrapper for Antigravity in Kasm Sandbox

# 1. Environment Fix for Electron Children
export ELECTRON_DISABLE_SANDBOX=1

# 2. Process Type Detection
IS_GUI_CHILD=0
for arg in "$@"; do
    if [[ "$arg" == --type=* ]]; then
        IS_GUI_CHILD=1
        break
    fi
done

# 3. Execution Logic
if [ "$ELECTRON_RUN_AS_NODE" = "1" ] && [ "$IS_GUI_CHILD" = "0" ] && [[ "$*" == *cli.js* ]]; then
    # Pure CLI Node mode - NO sandbox flags allowed here
    exec /usr/share/antigravity/antigravity-bin "$@"
fi

# Everything else is a GUI process or a child process requiring Chromium flags
unset ELECTRON_RUN_AS_NODE
exec /usr/share/antigravity/antigravity-bin \
    --no-sandbox \
    --disable-dev-shm-usage \
    --disable-zygote \
    --disable-namespace-sandbox \
    "$@"
EOF
    chmod +x /usr/share/antigravity/antigravity

    # Apply to legacy path for compatibility with any scripts hardcoding it
    cp /usr/share/antigravity/antigravity /usr/share/antigravity/antigravity-original
    chmod +x /usr/share/antigravity/antigravity-original
}

ensure_chrome_protection() {
    print_info "Verifying Chrome protection mechanisms..."
    if ! dpkg-divert --list | grep -q "/opt/google/chrome/google-chrome"; then
        print_warning "Chrome dpkg-divert missing. Applying robust protection..."
        if [ -f /opt/google/chrome/google-chrome-original ]; then
            dpkg-divert --add --divert /opt/google/chrome/google-chrome-original /opt/google/chrome/google-chrome
        else
            dpkg-divert --add --rename --divert /opt/google/chrome/google-chrome-original /opt/google/chrome/google-chrome
        fi
    fi

    # Always re-write wrapper to ensure --no-sandbox is present
    rm -f /opt/google/chrome/google-chrome || true
    cat << 'EOF' > /opt/google/chrome/google-chrome
#!/bin/bash
exec /opt/google/chrome/google-chrome-original --no-sandbox --disable-dev-shm-usage "$@"
EOF
    chmod +x /opt/google/chrome/google-chrome
}

update_ide() {
    print_info "Starting IDE Update Process..."
    
    ensure_wrapper_protection
    ensure_chrome_protection

    print_info "Updating package lists..."
    apt-get update -y
    
    # We only want to upgrade antigravity, but we do it safely
    print_info "Upgrading Antigravity IDE (Only)..."
    if apt-get install --only-upgrade -y antigravity; then
        # Clean caches which might cause crashes after updates
        print_info "Cleaning up old electron caches to prevent renderer crashes..."
        find /home -name "GPUCache" -type d -exec rm -rf {} + 2>/dev/null || true
        find /home -name ".config/antigravity" -type d -exec rm -rf {}/GPUCache + 2>/dev/null || true
        
        print_success "IDE update completed successfully."
    else
        print_error "Failed to update package."
        exit 1
    fi
}

reinstall_ide() {
    echo -e "${RED}${BOLD}WARNING: This will completely wipe the existing Antigravity installation.${NC}"
    echo "It is recommended to only run this if the IDE is crashing continuously."
    
    print_info "Removing existing Antigravity IDE..."
    # Warning: when we purge, dpkg-divert might complain or get removed
    apt-get remove --purge -y antigravity || true
    
    # Temporarily remove divergence for a clean slate
    print_info "Resetting diversion rules for clean slate..."
    dpkg-divert --rename --remove /usr/share/antigravity/antigravity || true
    # Remove lingering original binaries if any
    rm -f /usr/share/antigravity/antigravity-original || true
    rm -f /usr/share/antigravity/antigravity-bin || true

    print_info "Installing fresh Antigravity IDE..."
    apt-get update -y
    apt-get install -y antigravity

    # Re-apply the protective wrapper
    print_info "Re-applying Sandbox container protections..."
    ensure_wrapper_protection
    ensure_chrome_protection

    print_info "Cleaning up corrupted user configurations..."
    find /home -type d -name ".config/antigravity" -exec rm -rf {} + 2>/dev/null || true

    print_success "IDE Reinstallation completed successfully."
}

# Main Command Router
if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

case "$1" in
    update-ide)
        update_ide
        ;;
    reinstall-ide)
        reinstall_ide
        ;;
    help)
        show_help
        ;;
    *)
        print_error "Unknown command: $1"
        show_help
        exit 1
        ;;
esac
